{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "viewer-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "viewer"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "viewer",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "http.server", "8899", "--directory", "."],
      "port": 8899
    },
    {
      "name": "viewer-static-b",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "http.server", "8901", "--directory", "."],
      "port": 8901
    },
    {
      "name": "viewer-static-c",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "http.server", "8903", "--directory", "."],
      "port": 8903
    },
    {
      "name": "compare-viewer",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "http.server", "8777", "--directory", "out/compare"],
      "port": 8777
    }
  ]
}
